# Google Gemini API Configuration
# Get your API key from: https://ai.google.dev/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Token (for higher API rate limits)
# Get from: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=your_github_token_here

# Supabase Auth + Database (required for login/profile features)
# Create project at: https://supabase.com/
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Billing (required for Pro/Team subscriptions)
# Get price IDs from your Stripe Dashboard > Products
VITE_STRIPE_PRO_PRICE_ID=price_xxx
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
VITE_STRIPE_TEAM_PRICE_ID=price_xxx
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=price_xxx
# Stripe secret key goes in Vercel env vars (server-side only, NOT prefixed with VITE_)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Free plan daily usage limit
VITE_FREE_DAILY_ANALYSIS_LIMIT=3

# Analytics (optional)
VITE_ENABLE_ANALYTICS=false
