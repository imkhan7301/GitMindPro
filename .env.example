# Google Gemini API Configuration
# Get your API key from: https://ai.google.dev/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Token (for higher API rate limits)
# Get from: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=your_github_token_here

# ─── Supabase ────────────────────────────────────────────────────────────────
# Create project at: https://supabase.com/
# VITE_ vars are used client-side (auth + queries)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-side only (used by api/webhook.js and api/portal.js — add to Vercel env vars)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Stripe ──────────────────────────────────────────────────────────────────
# CLIENT-SIDE: price IDs shown in PricingModal (VITE_ prefix, safe to expose)
# Get from: Stripe Dashboard > Products > your product > Pricing
VITE_STRIPE_PRO_PRICE_ID=price_xxx
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
VITE_STRIPE_TEAM_PRICE_ID=price_xxx
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=price_xxx

# SERVER-SIDE ONLY (add to Vercel env vars — DO NOT prefix with VITE_)
# Secret key: Stripe Dashboard > Developers > API keys > Secret key
STRIPE_SECRET_KEY=sk_live_xxx
# Same price IDs without VITE_ — used by webhook to resolve plan name
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx
# Webhook secret: Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Misc ────────────────────────────────────────────────────────────────────
# Free plan daily usage limit
VITE_FREE_DAILY_ANALYSIS_LIMIT=3

# Analytics (optional)
VITE_ENABLE_ANALYTICS=false
